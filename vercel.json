{
  "version": 2,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "data/**"
    },
    "api/**": {
      "includeFiles": ["data/**", "firebase-applet-config.json", "dist/**", "scripts/**", "css/**"]
    }
  }
}
