{
  "version": 2,
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index"
    }
  ],
  "functions": {
    "api/**/*": {
      "includeFiles": "{data/**,firebase-applet-config.json,dist/**,scripts/**,css/**}"
    }
  }
}
